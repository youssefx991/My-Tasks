@{
    var allEmps = ViewBag.employees;
}

<h1>getAll</h1>

<table class="table table-bordered table-hover">
    <thead>
        <tr>
            <th>Emp Id</th>
            <th>Emp Name</th>
            <th>Emp Age</th>
            <th>Emp Email</th>

            <th> &nbsp; </th>
            <th> &nbsp; </th>
            <th> &nbsp; </th>
        </tr>
    </thead>
    <tbody>
       
        @* @foreach (var emp in  allEmps) *@
        @foreach (var emp in (List<Employee>)allEmps)
        {
            <tr>
                <td>@emp.Id</td>
                <td>@emp.Name</td>
                <td>@emp.Age</td>
                <td>@emp.Email</td>

                <td> <a href="/Employee/getById/@emp.Id" class="btn btn-primary"> Select </a> </td>

                <td> <a href="/Employee/Edit/@emp.Id" class="btn btn-info"> Edit </a> </td>

                <td> <a href="/Employee/Delete/@emp.Id" class="btn btn-danger"> Delete </a> </td>
            </tr>
        }
    </tbody>
</table>