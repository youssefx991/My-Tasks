@model Day5_46.Models.City

@{
    List<Country> CountryLst = (List<Country>)ViewBag.cID;
}

<h1>Edit</h1>

<h4>City</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post" action="/City/Edit">
            
            @Html.HiddenFor(m => m.CityID)

            <div class="form-group">
                @Html.DisplayNameFor(m => m.CityName)
                @Html.EditorFor(m => m.CityName, new { @class = "form-control" })
            </div>

            <div class="form-group">
                @Html.DisplayNameFor(m => m.cID)
                @* @Html.EditorFor(m => m.cID, new { @class = "form-control" }) *@
                
                <select name="cID" class="form-control">
                    @foreach (var item in CountryLst)
                    {
                        if(item.CountryID == Model.cID)
                        {
                            <option value="@item.CountryID" selected>@item.CountryName</option>
                        }
                        else
                        {
                            <option value="@item.CountryID">@item.CountryName</option>
                        }
                    }
                </select>
            </div>

            <input type="submit" value="Save" />

        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

