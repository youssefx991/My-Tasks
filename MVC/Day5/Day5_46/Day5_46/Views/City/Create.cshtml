@model Day5_46.Models.City

@{
    SelectList CountryLst = new SelectList((List<Country>)ViewBag.cID, "CountryID", "CountryName");
}

<h1>Create</h1>

<h4>City</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div class="form-group">
                <label asp-for="CityName" class="control-label"></label>
                <input asp-for="CityName" class="form-control" />
            </div>
            <div class="form-group">
                <label asp-for="cID" class="control-label"></label>
                @* <input asp-for="cID" class="form-control" /> *@
                <select asp-for="cID" class="form-control" asp-items="@CountryLst"></select>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

